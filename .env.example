# Container name prefix
CONTAINER_NAME_PREFIX=booktracker

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-it-please
POSTGRES_DB=booktracker_db

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Backend
BACKEND_PORT=4000
DB_HOST=localhost
